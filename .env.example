# Public site URL used for SEO metadata, canonical URLs, and sitemap generation.
NEXT_PUBLIC_SITE_URL=https://example.com

# TinaCMS public client ID used by the admin CMS UI.
NEXT_PUBLIC_TINA_CLIENT_ID=your_tina_public_client_id

# TinaCMS read/write token used server-side for content editing.
TINA_TOKEN=your_tina_token

# Branch name for TinaCMS on Vercel previews/production.
# Vercel usually provides VERCEL_GIT_COMMIT_REF automatically.
VERCEL_GIT_COMMIT_REF=main

# Optional client-exposed branch override for TinaCMS.
# Leave aligned with the active Vercel Git branch if you set it manually.
NEXT_PUBLIC_VERCEL_GIT_COMMIT_REF=main

# Google Analytics 4 measurement ID for browser + server event tracking.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Analytics 4 Measurement Protocol API secret for server-side events.
GA4_API_SECRET=your_ga4_api_secret

# Google Search Console service account email for admin analytics dashboards.
GSC_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com

# Google Search Console service account private key.
# Keep literal \n sequences if storing as a single-line environment variable.
GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Search Console property URL queried by the admin analytics dashboard.
GSC_SITE_URL=https://example.com/

# Optional Microsoft Clarity project ID for client analytics.
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# Optional Plausible site domain for client analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=example.com

# Optional PostHog project API key for client analytics.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key

# Optional PostHog host; defaults to https://app.posthog.com if omitted.
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google AdSense publisher ID for article ad placements.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Google AdSense slot for the article sidebar rectangle unit.
NEXT_PUBLIC_AD_SLOT_SIDEBAR=1234567890

# Google AdSense slot for the in-content article ad unit.
NEXT_PUBLIC_AD_SLOT_INCONTENT=0987654321

# Runtime mode flag. Usually set automatically by Node/Vercel.
NODE_ENV=development
